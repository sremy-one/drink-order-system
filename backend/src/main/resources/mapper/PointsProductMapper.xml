<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drinkorder.mapper.PointsProductMapper">

    <resultMap id="PointsProductResultMap" type="com.drinkorder.entity.PointsProduct">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="points_required" property="pointsRequired"/>
        <result column="stock" property="stock"/>
        <result column="image" property="image"/>
    </resultMap>

    <select id="findById" resultMap="PointsProductResultMap">
        SELECT * FROM points_products WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="PointsProductResultMap">
        SELECT * FROM points_products
    </select>

    <insert id="insert" parameterType="com.drinkorder.entity.PointsProduct">
        INSERT INTO points_products (name, description, points_required, stock, image)
        VALUES (#{name}, #{description}, #{pointsRequired}, #{stock}, #{image})
    </insert>

    <update id="update" parameterType="com.drinkorder.entity.PointsProduct">
        UPDATE points_products SET
            name = #{name},
            description = #{description},
            points_required = #{pointsRequired},
            stock = #{stock},
            image = #{image}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM points_products WHERE id = #{id}
    </delete>

    <update id="updateStock">
        UPDATE points_products SET stock = #{stock} WHERE id = #{id}
    </update>

</mapper>
