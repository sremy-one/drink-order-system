<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drinkorder.mapper.RewardMapper">

    <resultMap id="RewardResultMap" type="com.drinkorder.entity.Reward">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="points" property="points"/>
        <result column="stock" property="stock"/>
    </resultMap>

    <select id="findById" resultMap="RewardResultMap">
        SELECT * FROM rewards WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="RewardResultMap">
        SELECT * FROM rewards
    </select>

    <insert id="insert" parameterType="com.drinkorder.entity.Reward">
        INSERT INTO rewards (name, description, points, stock)
        VALUES (#{name}, #{description}, #{points}, #{stock})
    </insert>

    <update id="update" parameterType="com.drinkorder.entity.Reward">
        UPDATE rewards SET
            name = #{name},
            description = #{description},
            points = #{points},
            stock = #{stock}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM rewards WHERE id = #{id}
    </delete>

    <update id="updateStock">
        UPDATE rewards SET stock = #{stock} WHERE id = #{id}
    </update>

</mapper>
